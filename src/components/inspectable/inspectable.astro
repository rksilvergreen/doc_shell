---
/**
 * Inspectable — wraps content in a clickable container that opens a
 * zoomable/pannable inspection modal on click.  Ideal for diagrams,
 * images, and SVGs that benefit from closer examination.
 */
import "./inspectable.css";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["doc-inspectable", className]} tabindex="0" role="button">
  <slot />
</div>

<script src="./inspectable.ts"></script>
